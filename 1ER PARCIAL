#1. B  Funcion recursiva para listar los superheroes 

def  listado_heroes(lista_obj: List, pos: int = 0) -> None:
    if pos >= len(lista_obj):
        return
    
    print(f"{lista_obj[pos]['name']}")
    listado_heroes(lista_obj, pos+1)
