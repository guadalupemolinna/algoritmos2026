##1.A FUNCIÓN RECURSIVA PARA BUSCAR
def buscar_superheroe(lista_obj: List, buscado: str, pos: int = 0) -> bool:
    if pos >= len(lista_obj): #caso base: no se encontró el superheroe
        return False
    
    if lista_obj[pos]['name'].lower() == buscado.lower():
        return True
    
    return buscar_superheroe(lista_obj, buscado, pos+1) #llamada recursiva con la sig posicion

